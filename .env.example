# =============================================================================
# StellarBounty — Environment Variables
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellar_bounty

# PostgreSQL pool settings used by TypeORM / node-postgres.
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECT_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Secret key for signing JWT tokens (required)
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change_me_in_production
# Nonce TTL for wallet challenge in milliseconds (optional, defaults to 300000 = 5 min)
AUTH_NONCE_TTL_MS=300000

# JWT lifetimes. Keep access tokens short in production; refresh token support
# can use the longer refresh lifetime when implemented.
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Stellar Network (Backend)
# ---------------------------------------------------------------------------
# Network to interact with: "testnet" or "mainnet" (required)
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Optional: custom Soroban RPC endpoint. Defaults to the standard network URL if unset.
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Optional: server-side signing secret for Soroban contract interactions.
# If unset, contract transactions are prepared but not submitted — the client
# is expected to sign and submit them separately.
# STELLAR_SIGNING_SECRET=S...

# Optional: default Soroban contract ID to call for bounty payouts.
# SOROBAN_CONTRACT_ID=C...

# Optional: maximum fee cap in stroops for Stellar transactions (default: 100000 = 0.01 XLM)
# STELLAR_MAX_FEE=100000

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Port for the NestJS backend (optional, defaults to 4000)
PORT=4000

# Environment mode (optional, defaults to "development")
NODE_ENV=development

# Logging
# Allowed values: debug, verbose, log (default), info, warn, error
LOG_LEVEL=log
# Service name emitted in every structured log entry
SERVICE_NAME=stellar-bounty-backend

# ---------------------------------------------------------------------------
# Frontend (NEXT_PUBLIC_* variables are exposed to the browser)
# ---------------------------------------------------------------------------
# Backend API URL used by the Next.js frontend (default: http://localhost:4000)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Network the frontend wallet should target (optional, defaults to "TESTNET")
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
